{
  "version": 2,
  "builds": [
    {
      "src": "web/dist/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "web/dist/assets/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "web/dist/assets/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "web/dist/*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "src/api/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/api/server.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/web/dist/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/web/dist/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/web/dist/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/web/dist/index.html"
    }
  ]
}
